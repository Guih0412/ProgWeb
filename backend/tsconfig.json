{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/app.ts",
    "src/routes/continentes.ts",
    "src/routes/paises.ts",
    "src/routes/cidades.ts",
    "src/routes/external.ts",
    "src/middleware/errorHandler.ts"
  ]
}
